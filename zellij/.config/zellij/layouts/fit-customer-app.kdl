layout {
    pane split_direction="vertical" {
        pane split_direction="horizontal" {
            pane cwd="/home/mukund/workarea/getforj/spark" name="spark-api" command="zsh" {
                args "-c" "npm run api:fitting; exec zsh"
            }
            pane cwd="/home/mukund/workarea/getforj/in-bay-orchestrator" name="in-bay-orchestrator" command="zsh" {
                args "-c" "uv run uvicorn app.main:app --reload --port 8082; exec zsh"
            }
        }
        pane split_direction="horizontal" {
            pane cwd="/home/mukund/workarea/getforj/teebox-fit-app" name="teebox-fit-app" command="zsh" {
                args "-c" "npm run dev; exec zsh"
            }
            pane cwd="/home/mukund/workarea/getforj/fit-customer-app" name="fit-customer-app" command="zsh" {
                args "-c" "npm run dev; exec zsh"
            }
        }
    }
}
